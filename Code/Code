// === YOUR EXACT L298N PINS ===
const int ENA = 9;  // Left motor speed
const int IN1 = 8;  // Left motor direction 1
const int IN2 = 7;  // Left motor direction 2
const int IN3 = 5;  // Right motor direction 1
const int IN4 = 4;  // Right motor direction 2
const int ENB = 3;  // Right motor speed

void setup() {
  Serial.begin(115200);
  pinMode(ENA, OUTPUT);
  pinMode(ENB, OUTPUT);
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  stopTank();
  Serial.println("TANK READY - Type F, B, L, R, S + ENTER");
}

// === FIXED MOVEMENTS ===
void tankForward() {
  digitalWrite(IN1, HIGH); digitalWrite(IN2, LOW);   // Left forward
  digitalWrite(IN3, HIGH); digitalWrite(IN4, LOW);   // Right forward
  analogWrite(ENA, 200); analogWrite(ENB, 200);
  Serial.println("FORWARD");
}

void tankBackward() {
  digitalWrite(IN1, LOW);  digitalWrite(IN2, HIGH);  // Left backward
  digitalWrite(IN3, LOW);  digitalWrite(IN4, HIGH);  // Right backward
  analogWrite(ENA, 200); analogWrite(ENB, 200);
  Serial.println("BACKWARD");
}

// FIXED: Left command now does RIGHT turn
void tankLeft() {
  digitalWrite(IN1, HIGH); digitalWrite(IN2, LOW);   // Left FORWARD  
  digitalWrite(IN3, LOW);  digitalWrite(IN4, HIGH);  // Right BACKWARD
  analogWrite(ENA, 150); analogWrite(ENB, 150);
  Serial.println("RIGHT");  // Now turns RIGHT when you type L
}

// FIXED: Right command now does LEFT turn  
void tankRight() {
  digitalWrite(IN1, LOW);  digitalWrite(IN2, HIGH);  // Left BACKWARD
  digitalWrite(IN3, HIGH); digitalWrite(IN4, LOW);   // Right FORWARD
  analogWrite(ENA, 150); analogWrite(ENB, 150);
  Serial.println("LEFT");   // Now turns LEFT when you type R
}

void stopTank() {
  digitalWrite(IN1, LOW); digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW); digitalWrite(IN4, LOW);
  analogWrite(ENA, 0); analogWrite(ENB, 0);
  Serial.println("STOP");
}

void loop() {
  if (Serial.available() > 0) {
    char cmd = Serial.read();
    
    switch (cmd) {
      case 'F': case 'f': tankForward(); break;
      case 'B': case 'b': tankBackward(); break;
      case 'L': case 'l': tankLeft(); break;     // L = RIGHT turn
      case 'R': case 'r': tankRight(); break;    // R = LEFT turn
      case 'S': case 's': stopTank(); break;
      default: break;
    }
  }
}
